[Unit]
Description=Pi Server (Express + Socket.io)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/zerocool/pi-server
ExecStart=/usr/bin/node /home/zerocool/pi-server/server.js
Restart=on-failure
RestartSec=5
Environment=PORT=80
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
